<Window x:Class="EyewearManagementSystemWPF.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EyewearManagementSystemWPF"
        mc:Ignorable="d"
        Title="Login" 
        Height="450" 
        Width="800"
        WindowStartupLocation="CenterScreen"
        
        Background="#111">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        
    <!--Left-->
        <!--BackGround-->
        <Image Stretch="Fill"
               Source="/assest/Login.png"/>
        <!--Logo-->
        <Image Source="/assest/LOGO.png"
               Width="150"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Margin="-21,-17,0,0"/>

        <!--Text-->
        <StackPanel Grid.Column="0"
            Orientation="Vertical">
            <TextBlock  Foreground="White"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        FontSize="24"
                        FontWeight="Bold"
                        Margin="20,50,0,0">
                <TextBlock.LayoutTransform>
                    <RotateTransform Angle="-90"/>
                </TextBlock.LayoutTransform>
        <Run Text="LOOK"/>
        <Run Text=" SHARP"
             Foreground="#00FFCC"/>
            </TextBlock>
            <TextBlock
               Foreground="White"
               HorizontalAlignment="Right"
               FontSize="24"
               FontWeight="Bold"
               Margin="0,0,10,40" Height="35">
                <TextBlock.LayoutTransform>
                    <RotateTransform Angle="90"/>
                </TextBlock.LayoutTransform>
        <Run Text="SEE"/>
        <Run Text="SHARPER" Foreground="Aqua"/>
            </TextBlock>
        </StackPanel>
        
        
        <!--RIGHT-->
        <Border Grid.Column="1"
                Background="White"
                CornerRadius="10"
                Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>



                <StackPanel Grid.Row="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="260">

                    <TextBlock Text="Welcome Back!"
                               FontSize="20"           
                               FontWeight="Bold"           
                               Margin="0,0,0,12"           
                               HorizontalAlignment="Center"           
                               Foreground="#2C3E50"/>
                    <!-- Staff Login Panel-->
                    <StackPanel x:Name="StaffPanel" Margin="0,6,0,0">
                        <!--Username-->
                        <TextBlock Text="Username" 
                                       FontSize="14"
                                       Margin="15,8,0,2"
                                       Foreground="Gray"/>
                        <TextBox x:Name="txtUsername"
                                 Height="28"
                                 Margin="0,0,0,10"
                                 Width="230"
                                 Background="#F5F5F5"
                                 BorderThickness="1"
                                 BorderBrush="Gray"
                                 VerticalContentAlignment="Center">
                        </TextBox>
                        <!--Password-->
                        <TextBlock Text="Password" 
                                       FontSize="14"
                                       Margin="15,6,0,2"
                                       Foreground="Gray"/>

                        <PasswordBox x:Name="pwdBox"
                                         Height="28"                                           
                                         Margin="0,0,0,10"           
                                         Width="230"
                                         VerticalContentAlignment="Center"
                                         Background="#F5F5F5">
                        </PasswordBox>
                        <Border CornerRadius="8"
                                    Background="#3B82F6"
                                    Width="220">
                                <Button x:Name="btnLogin"
                                        Content="Login" Click="btnLogin_Click"
                                        Height="32"
                                        Background="Transparent"
                                        Foreground="White"
                                        BorderThickness="0"/>
                            </Border>
                            <TextBlock x:Name="txtStatus"
                                   Foreground="Red"
                                   Margin="0,12,0,0"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"/>
                        
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
