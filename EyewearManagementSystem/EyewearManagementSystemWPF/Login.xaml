<Window x:Class="EyewearManagementSystemWPF.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EyewearManagementSystemWPF"
        mc:Ignorable="d"
        Title="Login" 
        Height="450" 
        Width="800"
        WindowStartupLocation="CenterScreen"
        
        Background="#111">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        
    <!--Left-->
        <!--BackGround-->
        <Image Stretch="Fill"
               Source="C:\Users\ADMIN\Documents\GitHub\EyewareManagementWPF\EyewearManagementSystem\EyewearManagementSystemWPF\assest/Login.png"/>
        <!--Logo-->
        <Image Source="C:\Users\ADMIN\Documents\GitHub\EyewareManagementWPF\EyewearManagementSystem\EyewearManagementSystemWPF\assest/LOGO.png"
               Width="150"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Margin="-21,-17,0,0"/>

        <!--Text-->
        <StackPanel Grid.Column="0"
            Orientation="Vertical">
            <TextBlock
        Foreground="White"
        VerticalAlignment="Center"
        HorizontalAlignment="Left"
        FontSize="24"
        FontWeight="Bold"
        Margin="20,50,0,0">
                <TextBlock.LayoutTransform>
                    <RotateTransform Angle="-90"/>
                </TextBlock.LayoutTransform>
        <Run Text="LOOK"/>
        <Run Text=" SHARP"
             Foreground="#00FFCC"/>
            </TextBlock>
            <TextBlock
               Foreground="White"
               HorizontalAlignment="Right"
               FontSize="24"
               FontWeight="Bold"
               Margin="0,0,10,40" Height="35">
                <TextBlock.LayoutTransform>
                    <RotateTransform Angle="90"/>
                </TextBlock.LayoutTransform>
        <Run Text="SEE"/>
        <Run Text="SHARPER" Foreground="Aqua"/>
            </TextBlock>
        </StackPanel>
        
        
        <!--RIGHT-->
        <Border Grid.Column="1"
                Background="White"
                CornerRadius="10"
                Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Welcome Back!"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,12"
                           HorizontalAlignment="Center"
                           Foreground="#2C3E50"/>

                <StackPanel Grid.Row="1"
                            HorizontalAlignment="Center"
                            Width="260">
                    <!--Action Panel-->
                    <StackPanel x:Name="ActionPanel" VerticalAlignment="Center">
                        <TextBlock Text="Continue as customer or sign in as staff" 
                                   Foreground="Gray"
                                   TextAlignment="Center"
                                   Margin="0,0,0,12"
                                   FontSize="13"/>
                        <!--Continue as Customer-->
                        <Border CornerRadius="8"
                                BorderThickness="1"
                                Background="#3B82F6"
                                Height="36"
                                Margin="0,4">
                            <Button x:Name="btnContinue" 
                                    Content="Continue as Customer"
                                    Height="36"
                                    BorderThickness="0"
                                    Background="Transparent" Click="btnContinue_Click"/>
                        </Border>
                        <!--Staff Login-->
                        <Border CornerRadius="8"
                                Background="#3B82F6"
                                Height="36">
                            <Button x:Name="btnShowStafLogin"
                                    Content="Staff Login"
                                    Height="36"
                                    Background="Transparent"
                                    BorderThickness="0" Click="btnShowStafLogin_Click"/>
                        </Border>
                    </StackPanel>
                    
                    <!-- Staff Login Panel-->
                    <StackPanel x:Name="StaffPanel" Visibility="Collapsed" Margin="0,6,0,0">
                        <!--Username-->
                        <TextBlock Text="Username" 
                                       FontSize="14"
                                       Margin="15,8,0,2"
                                       Foreground="Gray"/>
                        <TextBox x:Name="txtUsername"
                                 Height="28"
                                 Margin="0,0,0,10"
                                 Width="230"
                                 Background="#F5F5F5"
                                 BorderThickness="1"
                                 BorderBrush="Gray"
                                 VerticalContentAlignment="Center">
                        </TextBox>
                        <!--Password-->
                        <TextBlock Text="Password" 
                                       FontSize="14"
                                       Margin="15,6,0,2"
                                       Foreground="Gray"/>

                        <PasswordBox x:Name="pwdBox"
                                         Height="28"                                           
                                         Margin="0,0,0,10"           
                                         Width="230"
                                         VerticalContentAlignment="Center"
                                         Background="#F5F5F5">
                        </PasswordBox>

                        

                        <StackPanel Orientation="Vertical"
                                        HorizontalAlignment="Center">
                            <Border CornerRadius="8"
                                    Background="#3B82F6"
                                    Width="220">
                                <Button x:Name="btnLogin"
                                        Content="Login" Click="btnLogin_Click"
                                        Height="32"
                                        Background="Transparent"
                                        Foreground="White"
                                        BorderThickness="0"/>
                            </Border>
                            <Button x:Name="btnBack"
                                    Content="Back"
                                    FontSize="13"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Margin="0,5"
                                    Click="btnBack_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="Gray"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#3B82F6"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="txtStatus"
                                   Foreground="Red"
                                   Margin="0,12,0,0"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
