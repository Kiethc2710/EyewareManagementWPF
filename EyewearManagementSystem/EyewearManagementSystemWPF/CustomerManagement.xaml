<Window x:Class="EyewearManagementSystemWPF.CustomerManagement"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý khách hàng" Height="550" Width="800" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- Trái: Form thông tin -->
        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,10,0">
            <StackPanel>
                <TextBlock Text="Thông tin khách hàng" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                
                <TextBlock Text="Mã khách hàng:" FontWeight="SemiBold"/>
                <TextBox x:Name="txtCustomerId" IsEnabled="False" Margin="0,5,0,10" Padding="5" Background="#EEEEEE"/>

                <TextBlock Text="Họ và tên (*):" FontWeight="SemiBold"/>
                <TextBox x:Name="txtFullName" Margin="0,5,0,10" Padding="5"/>

                <TextBlock Text="Số điện thoại (*):" FontWeight="SemiBold"/>
                <TextBox x:Name="txtPhone" Margin="0,5,0,10" Padding="5"/>

                <TextBlock Text="Địa chỉ:" FontWeight="SemiBold"/>
                <TextBox x:Name="txtAddress" Margin="0,5,0,20" Padding="5" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

                <UniformGrid Columns="2" Rows="2">
                    <Button Content="Thêm" x:Name="btnAdd" Margin="5" Padding="5" Background="LightGreen" Click="btnAdd_Click"/>
                    <Button Content="Cập nhật" x:Name="btnUpdate" Margin="5" Padding="5" Background="LightSkyBlue" Click="btnUpdate_Click"/>
                    <Button Content="Xóa" x:Name="btnDelete" Margin="5" Padding="5" Background="LightCoral" Click="btnDelete_Click"/>
                    <Button Content="Làm mới" x:Name="btnClear" Margin="5" Padding="5" Background="LightGray" Click="btnClear_Click"/>
                </UniformGrid>
            </StackPanel>
        </Border>

        <!-- Phải: Tìm kiếm & DataGrid -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Search Bar -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Tìm SĐT:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0"/>
                <TextBox x:Name="txtSearchPhone" Width="200" Padding="5" VerticalContentAlignment="Center"/>
                <Button Content="Tìm kiếm" x:Name="btnSearch" Width="80" Margin="10,0,0,0" Padding="5" Click="btnSearch_Click"/>
            </StackPanel>

            <!-- DataGrid -->
            <DataGrid Grid.Row="1" x:Name="dgCustomers" AutoGenerateColumns="False" 
                      IsReadOnly="True" SelectionMode="Single" SelectionChanged="dgCustomers_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã KH" Binding="{Binding CustomerId}" Width="60"/>
                    <DataGridTextColumn Header="Họ và Tên" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="Số điện thoại" Binding="{Binding Phone}" Width="120"/>
                    <DataGridTextColumn Header="Địa chỉ" Binding="{Binding Address}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>