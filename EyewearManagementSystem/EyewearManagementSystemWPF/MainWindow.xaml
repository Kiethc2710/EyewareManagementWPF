<Window x:Class="EyewearManagementSystemWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EyewearManagementSystemWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <DataGrid x:Name="dgCustomer"
            AutoGenerateColumns="False"
            Margin="5"
            SelectionMode="Single"
            CanUserAddRows="False" >
            <!--  chỉ đc chọn 1 tại thời điểm -->
            <DataGrid.Columns>
                <DataGridTextColumn Header="CustomerId" Binding="{Binding CustomerId}" Width="80"/>
                <DataGridTextColumn Header="FullName" Binding="{Binding FullName}" Width="150"/>
                <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="60"/>
                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="100"/>
            </DataGrid.Columns>

        </DataGrid>

    </Grid>
</Window>
