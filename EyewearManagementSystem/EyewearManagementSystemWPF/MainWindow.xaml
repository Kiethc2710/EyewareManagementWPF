<Window x:Class="EyewearManagementSystemWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Eyewear Management System" Height="850" Width="1300" 
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20" Background="#f5f6fa">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1.2*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1.5*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,10,15">
                <Button Content="📋 Invoice List" Width="130" Height="40" Background="#8e44ad" Foreground="White" FontWeight="Bold" Margin="0,0,10,0" Cursor="Hand" Click="Button_Click_OrderList">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="📦 Product Home" Width="140" Height="40" Background="#f39c12" Foreground="White" FontWeight="Bold" Margin="0,0,10,0" Cursor="Hand" Click="Button_Click_ProductHome">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="👤 + Customer" Width="130" Height="40" Background="#2ecc71" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="Button_Click_CustomerHome">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <Border x:Name="InvoiceSelectionBorder" Grid.Row="1" Background="White" CornerRadius="10" Padding="15" Margin="0,0,10,10" BorderBrush="#dcdde1" BorderThickness="1">
                <DockPanel>
                    <TextBlock Text="🛒 Product Selection" DockPanel.Dock="Top" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,15">
                        <ComboBox x:Name="cbProduct" Width="300" Height="38" DisplayMemberPath="ProductName" VerticalContentAlignment="Center"/>
                        <Button Content="Add to Invoice" Width="120" Margin="10,0" Background="#2ecc71" Foreground="White" FontWeight="Bold" Click="Button_Click_AddProduct">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>

                    <DataGrid x:Name="dgProductInvoice" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="None" RowHeight="40" FontSize="14" BorderThickness="0" AlternatingRowBackground="#f8f9fa" AlternationCount="2">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Background" Value="#ecf0f1"/>
                                <Setter Property="Padding" Value="10,5"/>
                            </Style>
                        </DataGrid.Resources>
                     <DataGrid.Columns>
    <DataGridTextColumn Header="Product Name" 
                        Binding="{Binding Product.ProductName}" 
                        Width="*" 
                        MinWidth="200"
                        IsReadOnly="True">
        <DataGridTextColumn.HeaderStyle>
            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Padding" Value="10,0,0,0"/>
            </Style>
        </DataGridTextColumn.HeaderStyle>
        <DataGridTextColumn.ElementStyle>
            <Style TargetType="TextBlock">
                <Setter Property="Padding" Value="10,0,0,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
        </DataGridTextColumn.ElementStyle>
    </DataGridTextColumn>

    <DataGridTextColumn Header="Price" 
                        Binding="{Binding Price, StringFormat={}{0:N0}}" 
                        Width="120" 
                        IsReadOnly="True">
        <DataGridTextColumn.HeaderStyle>
            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                <Setter Property="HorizontalContentAlignment" Value="Right"/>
                <Setter Property="Padding" Value="0,0,10,0"/>
            </Style>
        </DataGridTextColumn.HeaderStyle>
        <DataGridTextColumn.ElementStyle>
            <Style TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="Margin" Value="0,0,10,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
        </DataGridTextColumn.ElementStyle>
    </DataGridTextColumn>

    <DataGridTextColumn Header="Quantity" 
                        Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" 
                        Width="90">
        <DataGridTextColumn.HeaderStyle>
            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                <Setter Property="HorizontalContentAlignment" Value="Right"/>
                <Setter Property="Padding" Value="0,0,10,0"/>
            </Style>
        </DataGridTextColumn.HeaderStyle>
        <DataGridTextColumn.ElementStyle>
            <Style TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="Margin" Value="0,0,10,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
        </DataGridTextColumn.ElementStyle>
    </DataGridTextColumn>

    <DataGridTemplateColumn Header="" Width="60">
        <DataGridTemplateColumn.HeaderStyle>
            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}"/>
        </DataGridTemplateColumn.HeaderStyle>
        <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
                <Button Content="❌" 
                        Width="28" Height="28" 
                        Background="#ffe6e6" 
                        Foreground="Red" 
                        BorderThickness="0" 
                        Cursor="Hand" 
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Click="RemoveItem_Click"/>
            </DataTemplate>
        </DataGridTemplateColumn.CellTemplate>
    </DataGridTemplateColumn>
</DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="20" Margin="0,5,10,0" BorderBrush="#dcdde1" BorderThickness="1" x:Name="CustomerInfoBorder">
                <StackPanel>
                    <DockPanel Margin="0,0,0,15">
                        <TextBlock Text="👤 Customer Info" FontSize="16" FontWeight="Bold" Foreground="#2f3640"/>
                        <Separator Margin="10,0,0,0" VerticalAlignment="Center" Background="#f1f2f6"/>
                    </DockPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Phone" VerticalAlignment="Center" Foreground="#7f8c8d"/>
                        <TextBox x:Name="txtPhoneSearch" Grid.Column="1" Height="35" VerticalContentAlignment="Center" TextChanged="txtPhoneSearch_TextChanged"/>

                        <TextBlock Text="Name" Grid.Row="2" VerticalAlignment="Center" Foreground="#7f8c8d"/>
                        <TextBox x:Name="txtCustomerName" Grid.Row="2" Grid.Column="1" Height="35" IsReadOnly="True" Background="#f9f9f9" FontWeight="SemiBold" VerticalContentAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- PRODUCT MANAGEMENT VIEW (Added) -->
            <Border x:Name="ProductManagementView" Grid.Row="1" Grid.RowSpan="2" Background="White" CornerRadius="10" Padding="15" Margin="0,0,10,10" BorderBrush="#dcdde1" BorderThickness="1" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="📦 Product Management" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                    <!-- Inputs -->
                    <Grid Grid.Row="1" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Product Name:" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtManProductName" Grid.Row="0" Grid.Column="1" Margin="5" Padding="5"/>

                        <TextBlock Text="Brand:" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtManBrand" Grid.Row="1" Grid.Column="1" Margin="5" Padding="5"/>

                        <TextBlock Text="Price:" Grid.Row="0" Grid.Column="2" Margin="5" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtManPrice" Grid.Row="0" Grid.Column="3" Margin="5" Padding="5"/>

                        <TextBlock Text="Quantity:" Grid.Row="1" Grid.Column="2" Margin="5" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtManQuantity" Grid.Row="1" Grid.Column="3" Margin="5" Padding="5"/>

                        <TextBlock Text="Category:" Grid.Row="2" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                        <ComboBox x:Name="cboManCategory" Grid.Row="2" Grid.Column="1" Margin="5" Height="30" DisplayMemberPath="CategoryName" SelectedValuePath="CategoryId"/>

                        <StackPanel Grid.Row="3" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                            <Button Content="Add" Width="80" Height="30" Margin="10,0" Background="#2ecc71" Foreground="White" FontWeight="Bold" Click="btnManAdd_Click"/>
                            <Button Content="Update" Width="80" Height="30" Margin="10,0" Background="#f39c12" Foreground="White" FontWeight="Bold" Click="btnManUpdate_Click"/>
                            <Button Content="Delete" Width="80" Height="30" Margin="10,0" Background="#e74c3c" Foreground="White" FontWeight="Bold" Click="btnManDelete_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- DataGrid -->
                    <DataGrid x:Name="dgManProducts" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" SelectionChanged="dgManProducts_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Brand" Binding="{Binding Brand}" Width="*"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="*"/>
                            <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="*"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category.CategoryName}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="15" BorderBrush="#dcdde1" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="🧾 Invoice Preview" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="#f8f9fa" CornerRadius="5" Padding="10" Margin="0,0,0,15" BorderBrush="#eee" BorderThickness="1">
                            <StackPanel>
                                <DockPanel Margin="0,2">
                                    <TextBlock Text="Customer: " Foreground="#7f8c8d"/>
                                    <TextBlock Text="{Binding ElementName=txtCustomerName, Path=Text}" FontWeight="Bold"/>
                                </DockPanel>
                                <DockPanel Margin="0,2">
                                    <TextBlock Text="Phone: " Foreground="#7f8c8d"/>
                                    <TextBlock Text="{Binding ElementName=txtPhoneSearch, Path=Text}"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Item" FontSize="11" Foreground="#95a5a6"/>
                            <TextBlock Text="Qty" FontSize="11" Foreground="#95a5a6" Grid.Column="1" HorizontalAlignment="Center"/>
                            <TextBlock Text="Price" FontSize="11" Foreground="#95a5a6" Grid.Column="2" HorizontalAlignment="Right"/>
                        </Grid>
                        <Separator Margin="0,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding ElementName=dgProductInvoice, Path=ItemsSource}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Product.ProductName}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Quantity}" Grid.Column="1" HorizontalAlignment="Center" Foreground="#7f8c8d"/>
                                        <TextBlock Text="{Binding Price, StringFormat={}{0:N0}}" Grid.Column="2" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Background="#f1f2f6" CornerRadius="8" Padding="15" Margin="0,20,0,15">
                    <DockPanel>
                        <TextBlock Text="Total Amount:" VerticalAlignment="Center" FontWeight="Medium"/>
                        <TextBlock x:Name="txtTotal" Text="0" FontSize="24" FontWeight="Bold" Foreground="#e84118" HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                    </DockPanel>
                </Border>

                <Button Grid.Row="3" Content=" Create Invoice" Height="50" FontSize="16" FontWeight="Bold" Background="#0984e3" Foreground="White" Click="Button_Click_CreateInvoice_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>